{{! Native AresMUSH web portal template for the Inklings tab. }}
{{! See inklings-tab.js in the sibling app/components/ directory for }}
{{! the component class this template is paired with. Detail view lives }}
{{! in inkling-detail-modal.js / .hbs - this template only renders the }}
{{! list and the "New Inkling" form. }}

<div class="p-3 inklings-tab">

  <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <h2 class="mb-0">Inklings</h2>
    <div class="btn-group" role="group">
      <button type="button" class="btn btn-outline-secondary {{if (eq this.statusFilter "open") "active"}}" {{action "setStatusFilter" "open"}}>Open</button>
      <button type="button" class="btn btn-outline-secondary {{if (eq this.statusFilter "closed") "active"}}" {{action "setStatusFilter" "closed"}}>Closed</button>
      <button type="button" class="btn btn-outline-secondary {{if (eq this.statusFilter "all") "active"}}" {{action "setStatusFilter" "all"}}>All</button>
    </div>
    <button type="button" class="btn btn-primary" {{action "toggleNewForm"}}>
      {{if this.showNewForm "Cancel" "+ New Inkling"}}
    </button>
  </div>

  {{#if this.showNewForm}}
    <div class="card mb-3">
      <div class="card-body">
        <div class="mb-3">
          <label for="inklings-new-kind" class="form-label">Type</label>
          <select id="inklings-new-kind" class="form-select" onchange={{action "setNewKind" value="target.value"}}>
            <option value="">-- Select a type --</option>
            {{#each this.typeInfo as |t|}}
              <option value={{t.kind}}>{{t.name}}</option>
            {{/each}}
          </select>
        </div>
        <div class="mb-3">
          <label for="inklings-new-title" class="form-label">Title</label>
          {{input id="inklings-new-title" class="form-control" type="text" value=this.newTitle placeholder="Enter a short title"}}
        </div>
        <div class="mb-3">
          <label for="inklings-new-text" class="form-label">Text</label>
          {{textarea id="inklings-new-text" class="form-control" value=this.newText placeholder="Enter your inkling..." rows=4}}
        </div>
        <button type="button" class="btn btn-success" {{action "createInkling"}}>Create Inkling</button>
      </div>
    </div>
  {{/if}}

  {{#if this.loading}}
    <p>Loading inklings...</p>
  {{else if (eq this.inklings.length 0)}}
    <p class="text-center py-5 mb-0">No inklings yet.</p>
  {{else}}
    <ul class="inklings-list">
      {{#each this.inklings as |inkling|}}
        <li class="inkling-item border-bottom" {{action "openDetail" inkling.id}}>
          <div class="inkling-header">
            <h4 class="inkling-title">#{{inkling.id}} {{inkling.title}}</h4>
            <span class="badge text-bg-{{inkling.kind_color}}">{{inkling.kind_label}}</span>
            <span class="badge {{if (eq inkling.status "open") "text-bg-success" "text-bg-danger"}}">{{inkling.status}}</span>
            {{#if inkling.locked}}
              {{#if (eq inkling.approval_state "approved")}}
                <span class="badge text-bg-secondary">LOCKED - Completed</span>
              {{else if (eq inkling.approval_state "submitted")}}
                <span class="badge text-bg-secondary">LOCKED - Awaiting Staff Review</span>
              {{else}}
                <span class="badge text-bg-secondary">LOCKED</span>
              {{/if}}
            {{/if}}
          </div>
          <div class="inkling-meta">
            <span>{{inkling.message_count}} message{{if (eq inkling.message_count 1) "" "s"}}{{#if inkling.player_unread}} <span class="text-warning fw-bold">*</span>{{/if}}</span>
            {{#if inkling.linked_job}}
              <span class="badge text-bg-secondary">Job #{{inkling.linked_job.id}}</span>
            {{/if}}
            <span>{{local-date inkling.created_at 'MMM D, YYYY h:mm A'}}</span>
          </div>
        </li>
      {{/each}}
    </ul>
  {{/if}}

  {{inkling-detail-modal
    inklingId=this.selectedInklingId
    characterId=this.characterId
    viewerId=this.viewerId
    isStaff=this.isStaff
    onClose=(action "closeDetail")
    onUpdate=(action "inklingUpdated")
    onDelete=(action "inklingDeleted")
  }}

</div>
