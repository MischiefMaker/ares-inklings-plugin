{{! Detail view for a single inkling, in an ember-bootstrap modal. }}
{{! See inkling-detail-modal.js in the sibling app/components/ directory }}
{{! for the component class this template is paired with. }}
{{! NOTE: deliberately avoids the #with block helper with this.detail }}
{{! The #with block helper triggered Ember's "resolvedDefinition is null" }}
{{! recursive-error crash on this install (both here and in the original }}
{{! in-place-expansion template), for reasons that couldn't be pinned down }}
{{! further than "don't use #with with async data in this template". }}
{{! Every reference below goes through this.detail.* directly instead. }}

{{#bs-modal open=this.isOpen onHide=(action "close") size="lg" class="inklings-tab" as |modal|}}
  {{#modal.header closeButton=true}}
    {{#if this.detail}}
      <h4 class="modal-title">
        <span class="badge text-bg-{{this.detail.kind_color}}">{{this.detail.kind_label}}</span>
        {{this.detail.title}}
      </h4>
    {{else}}
      <h4 class="modal-title">Loading...</h4>
    {{/if}}
  {{/modal.header}}

  {{#modal.body}}
    {{#if this.loading}}
      <p>Loading...</p>
    {{else if this.detail}}

      {{#if (or this.detail.locked this.detail.tags.length)}}
        <div class="d-flex align-items-center gap-2 flex-wrap mb-3">
          {{#if this.detail.locked}}
            {{#if (eq this.detail.approval_state "approved")}}
              <span class="badge text-bg-secondary">LOCKED - Completed</span>
            {{else if (eq this.detail.approval_state "submitted")}}
              <span class="badge text-bg-secondary">LOCKED - Awaiting Staff Review</span>
            {{else}}
              <span class="badge text-bg-secondary">LOCKED</span>
            {{/if}}
          {{/if}}
          {{#each this.detail.tags as |tag|}}
            <span class="badge text-bg-secondary">
              {{tag}}
              {{#if (or this.isStaff (eq this.detail.character_id this.viewerId))}}
                <button type="button" class="btn-close btn-close-white ms-1" {{action "removeTag" tag}} aria-label="Remove tag"></button>
              {{/if}}
            </span>
          {{/each}}
        </div>
      {{/if}}

      {{#if this.detail.shared_with}}
        {{#if (or this.detail.shared_with.players.length this.detail.shared_with.groups.length)}}
          <div class="card card-body mb-3">
            <h6 class="mb-2">Shared With</h6>
            {{#if this.detail.shared_with.players.length}}
              <div class="small"><strong>Players:</strong> {{this.detail.shared_with.players}}</div>
            {{/if}}
            {{#if this.detail.shared_with.groups.length}}
              <div class="small"><strong>Groups:</strong> {{this.detail.shared_with.groups}}</div>
            {{/if}}
          </div>
        {{/if}}
      {{/if}}

      {{#if this.detail.rolls.length}}
        <h6>Rolls</h6>
        {{#each this.detail.rolls as |roll|}}
          <div class="border rounded p-2 mb-2 {{if roll.private "border-info border-2"}}">
            <div class="d-flex align-items-center gap-2 flex-wrap">
              <span class="small font-monospace">#{{roll.ref}}</span>
              <span class="badge text-bg-info">ROLL</span>
              <strong>{{roll.roll_spec}}</strong>
              {{#if (and (not (eq roll.roll_type "player")) roll.target_character)}}
                <span class="small fst-italic">for {{roll.target_character}}</span>
              {{/if}}
              {{#if roll.private}}<span class="badge text-bg-info text-uppercase">PRIVATE</span>{{/if}}
              <span class="fw-bold">{{ansi-format roll.result}}</span>
              <span class="small ms-auto">by {{roll.creator}}</span>
            </div>
          </div>
        {{/each}}
      {{/if}}

      <div class="messages-scroll mb-3">
        {{#each this.detail.messages as |msg|}}
          <div class="border-bottom pb-2 mb-2 {{if msg.is_staff "border rounded p-2"}} {{if msg.is_private "border-start border-info border-3 ps-2"}}">
            <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
              <span class="small font-monospace">#{{msg.ref}}</span>
              <strong>{{msg.author}}</strong>
              {{#if (eq msg.message_type "submitted")}}<span class="badge text-bg-info">SUBMITTED</span>{{/if}}
              {{#if (eq msg.message_type "approved")}}<span class="badge text-bg-success">APPROVED</span>{{/if}}
              {{#if (eq msg.message_type "needs_changes")}}<span class="badge text-bg-warning">NEEDS CHANGES</span>{{/if}}
              {{#if (eq msg.message_type "reward")}}<span class="badge text-bg-info">REWARD</span>{{/if}}
              {{#if (and msg.is_staff (not msg.message_type))}}<span class="badge text-bg-danger">STAFF</span>{{/if}}
              {{#if msg.is_gm_note}}<span class="badge text-bg-danger">GM</span>{{/if}}
              {{#if msg.is_personal}}<span class="badge text-bg-info">PRIVATE TO YOU</span>{{/if}}
              {{#if msg.is_private}}
                <span class="badge text-bg-info text-uppercase">
                  {{#if msg.private_recipient_label}}
                    PRIVATE TO {{msg.private_recipient_label}}
                  {{else if (not msg.is_staff)}}
                    PRIVATE TO STAFF
                  {{else}}
                    PRIVATE
                  {{/if}}
                </span>
              {{/if}}
              <span class="small ms-auto">{{local-date msg.created_at 'MMM D, YYYY h:mm A'}}</span>
            </div>
            <div class="message-text">{{msg.text}}</div>
          </div>
        {{/each}}
      </div>

      {{#if (eq this.detail.status "open")}}
        {{#if (and this.detail.locked (not this.isStaff))}}
          <div class="alert alert-secondary">
            This inkling has been submitted and is locked until staff respond. You'll be notified here when they do.
          </div>
        {{else}}
          <div class="mb-3">
            {{#unless this.showRollForm}}
              <button type="button" class="btn btn-success" {{action "toggleRollForm"}}>+ Add Roll</button>
            {{else}}
              <div class="card card-body">
                <div class="mb-3">
                  <label for="inklings-roll-type" class="form-label">Roll Type</label>
                  <select id="inklings-roll-type" class="form-select" onchange={{action "setRollType" value="target.value"}}>
                    <option value="player">FS3 Normal</option>
                    {{#if this.isStaff}}
                      <option value="npc">NPC Roll</option>
                      <option value="static">Static Number</option>
                    {{/if}}
                  </select>
                </div>

                {{#if (eq this.rollType "player")}}
                  <div class="mb-3">
                    <label for="inklings-roll-spec" class="form-label">Attribute/Skill</label>
                    {{input id="inklings-roll-spec" class="form-control" type="text" value=this.rollSpec placeholder="Enter attribute/skill name"}}
                  </div>
                {{/if}}

                {{#if (eq this.rollType "npc")}}
                  <div class="mb-3">
                    <label for="inklings-npc-name" class="form-label">NPC Name (optional)</label>
                    {{input id="inklings-npc-name" class="form-control" type="text" value=this.npcName placeholder="e.g. Guard Captain"}}
                  </div>
                {{/if}}

                {{#if (or (eq this.rollType "npc") (eq this.rollType "static"))}}
                  <div class="mb-3">
                    <label for="inklings-roll-spec-2" class="form-label">Skill / Attribute</label>
                    {{input id="inklings-roll-spec-2" class="form-control" type="text" value=this.rollSpec placeholder=(if (eq this.rollType "static") "Description" "Skill or attribute rolled")}}
                  </div>
                  <div class="mb-3">
                    <label for="inklings-roll-result" class="form-label">{{if (eq this.rollType "static") "Number" "Result"}}</label>
                    {{input id="inklings-roll-result" class="form-control" type="text" value=this.rollResult placeholder=(if (eq this.rollType "static") "Enter a number" "e.g. Good (7)")}}
                  </div>
                {{/if}}

                <div class="form-check mb-3">
                  {{input type="checkbox" class="form-check-input" id="inklings-roll-private" checked=this.rollIsPrivate}}
                  <label class="form-check-label" for="inklings-roll-private">
                    Private (only visible to player and staff)
                  </label>
                </div>

                <div class="d-flex gap-2">
                  <button type="button" class="btn btn-success" {{action "addRoll"}}>Add Roll</button>
                  <button type="button" class="btn btn-secondary" {{action "toggleRollForm"}}>Cancel</button>
                </div>
              </div>
            {{/unless}}
          </div>

          <div class="mb-3">
            {{#if this.replyIsPersonal}}
              <div class="alert alert-info">
                <strong>Personal Entry:</strong> Private notes visible only to you. These may become visible under game policies (transfers, roster changes, administration). Do not record sensitive out-of-game information.
              </div>
            {{/if}}
            {{textarea class="form-control mb-2" value=this.replyText placeholder="Add a reply..." rows="3"}}
            <div class="d-flex align-items-center gap-3 flex-wrap">
              <div class="form-check">
                {{input type="checkbox" class="form-check-input" id="inklings-reply-private" checked=this.replyIsPrivate}}
                <label class="form-check-label" for="inklings-reply-private">
                  Private (only you and staff can see this)
                </label>
              </div>
              <div class="form-check">
                {{input type="checkbox" class="form-check-input" id="inklings-reply-personal" checked=this.replyIsPersonal}}
                <label class="form-check-label" for="inklings-reply-personal">
                  Personal Entry (visible only to you)
                </label>
              </div>
              <button type="button" class="btn btn-success" {{action "submitReply"}}>Add Entry</button>
            </div>
          </div>

          {{#if (or this.isStaff (eq this.detail.character_id this.viewerId))}}
            <div class="mb-3">
              <div class="input-group">
                {{input class="form-control" type="text" value=this.tagInput placeholder="Add a tag..."}}
                <button type="button" class="btn btn-secondary" {{action "addTag"}}>Add Tag</button>
              </div>
            </div>
          {{/if}}

          {{#if (and (not this.isStaff) (eq this.detail.character_id this.viewerId) (not this.detail.locked))}}
            <div class="alert alert-warning">
              <p>So far this hasn't been sent to staff. Submit when you're ready for them to see it - you won't get a response until you do.</p>
              <button type="button" class="btn btn-primary" {{action "submitInkling"}}>Submit for Review</button>
            </div>
          {{/if}}
        {{/if}}

        {{#if (and this.detail.locked (eq this.detail.approval_state "approved") (eq this.detail.character_id this.viewerId) (not this.isStaff))}}
          <div class="alert alert-info d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>Need to make changes? Request that staff reopen this inkling.</span>
            <button type="button" class="btn btn-info" {{action "requestUnlock"}}>Request Unlock</button>
          </div>
        {{/if}}
      {{/if}}

      {{#if this.isStaff}}
        <hr>
        <div class="d-flex gap-2 flex-wrap mb-2">
          <button type="button" class="btn btn-secondary" {{action "addGmNote"}}>+ GM Note</button>
          {{#if (eq this.detail.approval_state "submitted")}}
            <button type="button" class="btn btn-success" {{action "approveInkling"}}>Approve</button>
            <button type="button" class="btn btn-warning" {{action "requestChanges"}}>Request Changes</button>
          {{/if}}
          {{#if (and this.detail.locked (eq this.detail.approval_state "approved"))}}
            <button type="button" class="btn btn-warning" {{action "unlockInkling"}}>Unlock</button>
          {{/if}}
          <button type="button" class="btn btn-info" {{action "grantReward"}}>Grant Reward</button>
        </div>
      {{/if}}

      {{#if (and (eq this.detail.status "open") (or this.isStaff (eq this.detail.character_id this.viewerId)))}}
        <hr>
        <div class="d-flex gap-2 flex-wrap align-items-center mb-2">
          <div class="input-group share-input-group">
            {{input class="form-control" type="text" value=this.shareTarget placeholder="Share with character(s)..."}}
            <button type="button" class="btn btn-secondary" {{action "shareInkling"}}>Share</button>
          </div>
          <div class="input-group share-input-group">
            {{input class="form-control" type="text" value=this.shareGroupTarget placeholder="Share with group(s)..."}}
            <button type="button" class="btn btn-secondary" {{action "shareGroup"}}>Share with Group</button>
          </div>
          <button type="button" class="btn btn-warning" {{action "closeInkling"}}>Close Inkling</button>
        </div>
      {{/if}}

      {{#if (or this.isStaff (eq this.detail.character_id this.viewerId))}}
        <button type="button" class="btn btn-danger" {{action "deleteInkling"}}>
          {{if this.isStaff "Delete Inkling" "Request Deletion"}}
        </button>
      {{/if}}

    {{/if}}
  {{/modal.body}}

  {{#modal.footer}}
    <button type="button" class="btn btn-secondary" {{action "close"}}>Close</button>
  {{/modal.footer}}
{{/bs-modal}}
