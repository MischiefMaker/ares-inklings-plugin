{{! Detail view for a single inkling, in an ember-bootstrap modal. }}
{{! See inkling-detail-modal.js in the sibling app/components/ directory }}
{{! for the component class this template is paired with. }}
{{! TEMPORARY DEBUG - stripped down to just the title to isolate the bug. }}

{{#bs-modal open=this.isOpen onHide=(action "close") size="lg" as |modal|}}
  {{#modal.header closeButton=true}}
    {{#if this.detail}}
      <h4 class="modal-title">
        <span class="badge text-bg-{{this.detail.kind_color}}">{{this.detail.kind_label}}</span>
        {{this.detail.title}}
      </h4>
    {{else}}
      <h4 class="modal-title">Loading...</h4>
    {{/if}}
  {{/modal.header}}

  {{#modal.body}}
    {{#if this.detail}}

      <div class="mb-3" style="max-height: 400px; overflow-y: auto;">
        {{#each this.detail.messages as |msg|}}
          <div class="border-bottom pb-2 mb-2">
            <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
              <span class="text-muted small font-monospace">#{{msg.ref}}</span>
              <strong>{{msg.author}}</strong>
              <span class="text-muted small ms-auto">{{local-date msg.created_at 'MMM D, YYYY h:mm A'}}</span>
            </div>
            <div style="white-space: pre-wrap; word-break: break-word;">{{msg.text}}</div>
          </div>
        {{/each}}
      </div>
    {{else}}
      <p>No detail loaded.</p>
    {{/if}}
  {{/modal.body}}

  {{#modal.footer}}
    <button type="button" class="btn btn-secondary" {{action "close"}}>Close</button>
  {{/modal.footer}}
{{/bs-modal}}
