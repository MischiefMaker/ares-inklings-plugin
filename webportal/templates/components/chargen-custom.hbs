{{!
  Chargen form fields for inkling required types (secret, goal, etc.)
  Auto-installed by plugin/install

  The form fields below are bound to char.custom.inkling_* values populated
  by get_fields_for_chargen in custom_char_fields.rb. When the chargen form
  advances past this step, the chargen-custom.js component's onUpdate()
  callback collects these values and passes them to save_fields_from_chargen.
}}

<div class="form-group">
  <label for="chargen-secret-title">Secret - Title</label>
  {{input
    id="chargen-secret-title"
    type="text"
    value=this.char.custom.inkling_secret_title
    placeholder="A short title for your secret"
    class="form-control"
  }}
</div>

<div class="form-group">
  <label for="chargen-secret-text">Secret - Description</label>
  {{textarea
    id="chargen-secret-text"
    value=this.char.custom.inkling_secret_text
    placeholder="Describe an IC secret your character holds..."
    rows="4"
    class="form-control"
  }}
</div>

<div class="form-group">
  <label for="chargen-goal-title">Goal - Title</label>
  {{input
    id="chargen-goal-title"
    type="text"
    value=this.char.custom.inkling_goal_title
    placeholder="A short title for your goal"
    class="form-control"
  }}
</div>

<div class="form-group">
  <label for="chargen-goal-text">Goal - Description</label>
  {{textarea
    id="chargen-goal-text"
    value=this.char.custom.inkling_goal_text
    placeholder="Describe what your character is working toward..."
    rows="4"
    class="form-control"
  }}
</div>
